generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  VISITOR
  EMPLOYEE
  RH
  COPATRON
  PATRON
  ADMIN
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum Gender {
  HOMME
  FEMME
  AUTRE
}

enum AnnouncementAudience {
  STAFF
  CITIZENS
}

enum Position {
  BARMAN
  SERVEUR
  SECURITE
  DJ
  DANSEUR
  RESPONSABLE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  discordId     String?   @unique
  role          Role      @default(VISITOR)
  createdAt     DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]

  applications      Recruitment[]        @relation("Applicant")
  reviewedApps      Recruitment[]        @relation("Reviewer")
  resignations      Resignation[]
  createdMeetings   Meeting[]            @relation("MeetingCreator")
  meetingParts      MeetingParticipant[]
  announcements     Announcement[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Recruitment {
  id           String            @id @default(cuid())
  applicantId  String

  // Informations personnelles
  fullName         String
  age              Int
  birthDate        DateTime
  gender           Gender
  phone            String

  // Poste souhaite
  desiredPosition  Position
  desiredSalary    String
  availability     String            @db.Text

  // Experience RP
  hasNightclubExp        Boolean   @default(false)
  previousNightclub      String?
  previousCompany        String?
  previousPosition       String?
  previousManager        String?
  departureReason        String?   @db.Text
  timeInPreviousCompany  String?

  // Motivations
  motivation       String            @db.Text

  // Informations RP
  hasCriminalRecord       Boolean  @default(false)
  criminalRecordDetails   String?  @db.Text
  hasDrivingLicense       Boolean  @default(false)
  canWorkNight            Boolean  @default(false)

  // Signature
  signature        String

  status        ApplicationStatus @default(PENDING)
  reviewedById  String?
  reviewNote    String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  applicant     User              @relation("Applicant", fields: [applicantId], references: [id], onDelete: Cascade)
  reviewer      User?             @relation("Reviewer", fields: [reviewedById], references: [id])

  @@index([status])
}

model Resignation {
  id        String   @id @default(cuid())
  userId    String
  reason    String   @db.Text
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Meeting {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.Text
  scheduledAt  DateTime
  location     String?
  createdById  String
  createdAt    DateTime @default(now())

  createdBy    User                  @relation("MeetingCreator", fields: [createdById], references: [id])
  participants MeetingParticipant[]

  @@index([scheduledAt])
}

model MeetingParticipant {
  id        String  @id @default(cuid())
  meetingId String
  userId    String

  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

model Announcement {
  id          String                @id @default(cuid())
  title       String
  content     String                @db.Text
  audience    AnnouncementAudience  @default(STAFF)
  imageUrl    String?               @db.Text
  createdById String
  createdAt   DateTime              @default(now())

  createdBy   User                  @relation(fields: [createdById], references: [id])

  @@index([createdAt])
}
